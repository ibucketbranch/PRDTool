<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Label (unique identifier) -->
    <key>Label</key>
    <string>com.user.document-monitor</string>
    
    <!-- Program to run -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/michaelvalderrama/Websites/TheConversation/venv/bin/python3</string>
        <string>/Users/michaelvalderrama/Websites/TheConversation/document_monitor.py</string>
        <string>--once</string>
    </array>
    
    <!-- Run on load (at login) -->
    <key>RunAtLoad</key>
    <true/>
    
    <!-- Run every 5 minutes (300 seconds) -->
    <key>StartInterval</key>
    <integer>300</integer>
    
    <!-- Environment variables -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>GROQ_API_KEY</key>
        <string>YOUR_GROQ_API_KEY_HERE</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    
    <!-- Working directory -->
    <key>WorkingDirectory</key>
    <string>/Users/michaelvalderrama/Websites/TheConversation</string>
    
    <!-- Standard output and error logs -->
    <key>StandardOutPath</key>
    <string>/Users/michaelvalderrama/.document_monitor_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/michaelvalderrama/.document_monitor_stderr.log</string>
    
    <!-- Keep alive (restart if crashes) -->
    <key>KeepAlive</key>
    <false/>
    
    <!-- Only run if connected to network -->
    <key>StartOnMount</key>
    <false/>
    
    <!-- Run only when user is logged in -->
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
</dict>
</plist>
