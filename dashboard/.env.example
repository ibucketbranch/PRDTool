# Supabase Configuration
# Copy this file to .env.local and fill in your values

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_ORGANIZER_BASE_PATH=/Users/you/Websites/PRDTool
# Base path for organized files (e.g. iCloud). Used for routing history, overrides, file DNA.
NEXT_PUBLIC_ICLOUD_BASE_PATH=/Users/you/Library/Mobile Documents/com~apple~CloudDocs
